# SwingScope API — Railway Environment Variables
# Copy these into Railway → Service → Variables

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# IMPORTANT: use postgresql+asyncpg:// for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Alpaca (Market Data) ────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Finnhub (News & Sentiment) ──────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key

# ─── Anthropic (optional LLM) ────────────────────────────────────────────────
# Not required — app works without it

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-random-string-here
ENVIRONMENT=production
MOCK_MODE=false

# ─── Scheduler (scan cron) ───────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCAN_CRON_SCHEDULE=30 23 * * 1-5

# ─── Execution Gateway (keep disabled until ready) ───────────────────────────
EXECUTION_ENABLED=false
EXECUTION_MODE=READ_ONLY
