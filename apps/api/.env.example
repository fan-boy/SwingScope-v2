SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# asyncpg format for SQLAlchemy + Alembic
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.yawvlizaahsmapwsckux.supabase.co:5432/postgres

SECRET_KEY=changeme-generate-with-openssl-rand-base64-32
ENVIRONMENT=development

# SMTP — works with Gmail App Password, Resend, SendGrid, Mailgun
# Gmail: smtp_host=smtp.gmail.com, smtp_port=587, use App Password
# Resend: smtp_host=smtp.resend.com, smtp_port=587, smtp_username=resend, smtp_password=<api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=SwingScope <you@gmail.com>

# Alerts
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=you@example.com

# Scheduler (opt-in — runs daily scan automatically)
SCHEDULER_ENABLED=false
SCAN_CRON_SCHEDULE=30 23 * * 1-5

# ── Execution gateway ────────────────────────────────────────────────────
# WARNING: changing these to live values will place real orders.
# Leave EXECUTION_ENABLED=false until you are 100% ready.
EXECUTION_ENABLED=false          # global kill switch
EXECUTION_MODE=READ_ONLY         # READ_ONLY | EXECUTE
ROBINHOOD_API_KEY=
ROBINHOOD_ACCOUNT_ID=
INTERNAL_API_KEY=                # generate: openssl rand -hex 32
